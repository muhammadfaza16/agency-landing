---
// 404.astro — Not found page
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Halaman Tidak Ditemukan">
  <div class="not-found">
    <div class="container not-found-inner">
      <span class="section-label">// 404</span>
      <h1 class="not-found-heading">
        Halaman ini<br />
        <em>nggak ada.</em>
      </h1>
      <p class="not-found-text">
        Yang lo cari nggak ketemu di sini. Mungkin URL-nya salah, atau halaman ini sudah dipindahin.
      </p>
      <a href="/" class="btn-primary">← Balik ke Home</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .not-found-inner {
    text-align: center;
    max-width: 520px;
  }

  .not-found-heading {
    margin-bottom: 1.25rem;
  }

  .not-found-text {
    color: var(--fg2);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
  }
</style>
