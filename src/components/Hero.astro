---
// Hero.astro — Full viewport hero with stat cards
const currentYear = new Date().getFullYear();
const techStack = ['Next.js', 'React', 'Supabase', 'Python', 'FastAPI', 'Vercel', 'Tailwind', 'Claude API'];
---

<section id="hero" class="hero">
  <div class="container hero-grid">
    <!-- Left: Copy (φ proportion — 61.8%) -->
    <div class="hero-copy">
      <div class="availability-badge">
        <span class="pulse-dot"></span>
        <span class="badge-text">Tersedia untuk proyek — {currentYear}</span>
      </div>

      <h1 class="text-balance">
        Ide jadi software<br />
        <em>rilis lebih</em><br />
        cepat.
      </h1>

      <p class="hero-sub text-balance">
        Ubah ide Anda menjadi software kualitas tinggi dalam hitungan minggu. Kami memadukan standar engineering studio profesional dengan ritme kerja yang ramping untuk memastikan visi Anda rilis dengan presisi.
      </p>

      <div class="hero-buttons">
        <a href="#cta" class="btn-primary">Diskusikan Proyek</a>
        <a href="#works" class="btn-ghost">Lihat Portofolio</a>
      </div>
    </div>

    <!-- Right: Stat Cards (38.2%) -->
    <div class="hero-stats">
      <div class="stat-card glass-card shadow-deep" style="--delay: 0.1s;">
        <span class="stat-label">Rata-rata pengerjaan</span>
        <span class="stat-value">3–6 <em>minggu</em></span>
      </div>

      <div class="stat-card glass-card shadow-deep" style="--delay: 0.2s;">
        <span class="stat-label">Proyek selesai</span>
        <span class="stat-value">12<span class="stat-accent">+</span></span>
      </div>

      <div class="stat-card glass-card stat-card-stack shadow-deep" style="--delay: 0.3s;">
        <span class="stat-label">Stack teknologi</span>
        <div class="stat-tags">
          {techStack.map((tech) => (
            <span class="stat-tag">{tech}</span>
          ))}
        </div>
      </div>

      <div class="stat-card glass-card shadow-deep" style="--delay: 0.4s;">
        <span class="stat-label">Kapasitas bulan ini</span>
        <div class="stat-status">
          <span class="pulse-dot"></span>
          <span class="stat-status-text">1 Slot Tersedia</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 5.5rem;
    padding-bottom: var(--sp-xl);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.618fr 1fr; /* golden ratio split */
    gap: var(--sp-xl);
    align-items: center;
  }

  /* Availability badge */
  .availability-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-xs);
    padding: var(--sp-2xs) 0.9rem;
    border: 0.5px solid var(--border2);
    margin-bottom: var(--sp-lg);
  }

  .badge-text {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Hero subtext */
  .hero-sub {
    font-size: 1.125rem; /* Proportion: φ⁻¹ scaling */
    color: var(--fg2);
    line-height: 1.7;
    margin-top: var(--sp-md);
    max-width: 520px;
    font-weight: 400;
  }

  /* Buttons */
  .hero-buttons {
    display: flex;
    gap: var(--sp-md);
    margin-top: var(--sp-lg);
    flex-wrap: wrap;
  }

  /* Stats grid */
  .hero-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
  }

  .stat-card {
    padding: var(--sp-md);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    opacity: 0;
    animation: fadeInUp 0.6s var(--ease-out-expo) forwards;
    animation-delay: var(--delay, 0s);
    border-radius: var(--sp-2xs);
  }

  .stat-card-stack {
    grid-column: span 2;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--fg3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 2.118rem; /* Proportion: φ² scaling */
    font-weight: 800;
    color: var(--fg);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .stat-value em {
    font-size: 1.1rem;
    color: var(--fg2);
  }

  .stat-accent {
    color: var(--accent);
  }

  .stat-tags {
    display: flex;
    gap: var(--sp-2xs);
    flex-wrap: wrap;
  }

  .stat-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.3rem var(--sp-xs);
    border: 0.5px solid var(--border2);
    color: var(--fg2);
    transition: border-color 0.2s ease;
  }

  .stat-tag:hover {
    border-color: var(--fg3);
  }

  .stat-status {
    display: flex;
    align-items: center;
    gap: var(--sp-xs);
  }

  .stat-status-text {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 500;
  }

  /* ─── Responsive ─── */
  @media (max-width: 960px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-lg);
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding-top: 6.5rem;
    }

    .hero-stats {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .hero-buttons {
      flex-direction: column;
    }

    .hero-buttons .btn-primary,
    .hero-buttons .btn-ghost {
      text-align: center;
      justify-content: center;
      width: 100%;
    }

    .hero-stats {
      grid-template-columns: 1fr;
    }

    .stat-card-stack {
      grid-column: span 1;
    }
  }
</style>
