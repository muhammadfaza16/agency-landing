---
// Works.astro — Selected works / portfolio
import { works } from '../data/works';
---

<section id="works" class="section">
  <div class="container">
    <span class="section-label">// 003 — Selected works</span>
    <h2 class="works-heading">
      Produk<br />
      <em>Nyata.</em>
    </h2>

    <div class="works-grid">
      {works.map((work) => (
        <article class="work-card glass-card glow-hover">
          <div class={`work-thumb work-thumb--${work.color}`}>
            <div class="work-thumb-inner">
              <span class="work-thumb-icon">↗</span>
            </div>
          </div>
          <div class="work-body">
            <span class="work-category">{work.category}</span>
            <h3 class="work-title text-balance">{work.title}</h3>
            <p class="work-desc text-balance">{work.desc}</p>
            <div class="work-footer">
              <span class="work-result">{work.result}</span>
              <span class="work-arrow">↗</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .works-heading {
    margin-bottom: var(--sp-lg);
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-md);
  }

  .work-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    cursor: pointer;
    border-radius: var(--sp-2xs);
  }

  .work-card:hover {
    transform: translateY(-6px);
  }

  .work-card:hover .work-arrow {
    transform: translate(3px, -3px);
    color: var(--accent);
  }

  .work-card:hover .work-thumb-inner {
    opacity: 1;
    transform: scale(1);
  }

  /* Thumbnail area — golden ratio aspect */
  .work-thumb {
    aspect-ratio: 1.618 / 1; /* golden ratio */
    position: relative;
    overflow: hidden;
    background-color: var(--bg3);
  }

  .work-thumb--accent {
    background: linear-gradient(135deg, rgba(200, 255, 0, 0.12), rgba(200, 255, 0, 0.04));
  }

  .work-thumb--accent2 {
    background: linear-gradient(135deg, rgba(255, 107, 53, 0.12), rgba(255, 107, 53, 0.04));
  }

  .work-thumb--neutral {
    background: linear-gradient(135deg, rgba(240, 238, 230, 0.08), rgba(240, 238, 230, 0.02));
  }

  .work-thumb-inner {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.15;
    transform: scale(0.95);
    transition: opacity 0.4s ease, transform 0.4s var(--ease-out-expo);
  }

  .work-thumb-icon {
    font-size: 2.5rem;
    color: var(--fg);
  }

  /* Card body */
  .work-body {
    padding: var(--sp-md);
    display: flex;
    flex-direction: column;
    gap: var(--sp-xs);
    flex-grow: 1;
  }

  .work-category {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    color: var(--fg3);
    letter-spacing: 0.05em;
  }

  .work-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .work-desc {
    font-size: 0.95rem;
    color: var(--fg2);
    line-height: 1.7;
    margin-bottom: var(--sp-2xs);
  }

  .work-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: var(--sp-md);
    border-top: 1px solid var(--border);
  }

  .work-result {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    font-weight: 500;
  }

  .work-arrow {
    font-size: 1.25rem;
    color: var(--fg3);
    transition: transform 0.3s var(--ease-out-expo), color 0.3s ease;
  }

  @media (max-width: 960px) {
    .works-grid {
      gap: var(--sp-md);
    }
  }

  @media (max-width: 640px) {
    .works-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
