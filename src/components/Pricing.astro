---
// Pricing.astro — 3-column pricing section
const plans = [
  {
    tier: 'Starter',
    price: 'Rp 8–15jt',
    unit: '/proyek',
    desc: 'Solusi untuk landing page atau produk digital dengan lingkup kerja yang terdefinisi jelas.',
    features: [
      'Landing page / marketing site',
      'Responsive design',
      'Basic SEO setup',
      'Deployment + hosting setup',
      '1 minggu support pasca-rilis',
    ],
    timeline: '1–2 minggu',
    featured: false,
  },
  {
    tier: 'Build',
    price: 'Rp 20–50jt',
    unit: '/proyek',
    desc: 'Pilihan utama bagi startup untuk membangun MVP atau web app dengan fitur lengkap.',
    features: [
      'Full-stack web application',
      'Auth + role management',
      'Database + API',
      'Admin dashboard',
      'Payment integration',
      'Deployment ke production',
      '2 minggu support pasca-rilis',
    ],
    timeline: '3–6 minggu',
    featured: true,
    badge: 'Paling sering dipilih',
  },
  {
    tier: 'Retainer',
    price: 'Rp 10jt',
    unit: '/bulan',
    desc: 'Dukungan berkelanjutan untuk pengembangan fitur baru, perbaikan, dan optimasi performa.',
    features: [
      '40 jam development/bulan',
      'Fitur baru + bug fixing',
      'Performance monitoring',
      'Priority response (< 4 jam)',
      'Monthly sprint planning',
    ],
    timeline: 'Min. 3 bulan',
    featured: false,
  },
];
---

<section id="pricing" class="section">
  <div class="container">
    <span class="section-label">// 004 — Pricing</span>
    <h2 class="pricing-heading">
      Harga yang<br />
      <em>Transparan.</em>
    </h2>

    <div class="pricing-grid">
      {plans.map((plan) => (
        <div class={`pricing-card glass-card ${plan.featured ? 'pricing-card--featured glow-hover shadow-deep' : ''}`}>
          {plan.featured && plan.badge && (
            <div class="pricing-badge">{plan.badge}</div>
          )}
          <div class="pricing-header">
            <span class="pricing-tier">{plan.tier}</span>
            <div class="pricing-price">
              <span class="pricing-amount">{plan.price}</span>
              <span class="pricing-unit">{plan.unit}</span>
            </div>
            <p class="pricing-desc text-balance">{plan.desc}</p>
          </div>

          <div class="pricing-timeline">
            <span class="pricing-timeline-label">Timeline:</span>
            <span class="pricing-timeline-value">{plan.timeline}</span>
          </div>

          <ul class="pricing-features">
            {plan.features.map((feature) => (
              <li class="pricing-feature">
                <span class="pricing-feature-arrow">→</span>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href="#cta"
            class={plan.featured ? 'btn-primary pricing-cta' : 'btn-ghost pricing-cta'}
          >
            Mulai Proyek
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing-heading {
    margin-bottom: var(--sp-lg);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-md);
  }

  .pricing-card {
    padding: var(--sp-lg);
    display: flex;
    flex-direction: column;
    position: relative;
    border-radius: var(--sp-2xs);
    border: 1px solid var(--glass-border);
  }

  .pricing-card--featured {
    border-color: rgba(200, 255, 0, 0.4);
    background: linear-gradient(180deg, rgba(200, 255, 0, 0.05) 0%, rgba(200, 255, 0, 0.01) 100%);
    transform: scale(1.05); /* Proportion: Dominate visual space */
    z-index: 2;
    box-shadow: 0 32px 64px -16px rgba(0, 0, 0, 0.6);
  }

  .pricing-card--featured:hover {
    transform: scale(1.07) translateY(-4px);
  }

  .pricing-badge {
    position: absolute;
    top: 0;
    right: var(--sp-md);
    background-color: var(--accent);
    color: #0A0A08;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.35rem 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .pricing-header {
    margin-bottom: var(--sp-md);
  }

  .pricing-tier {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--fg3);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .pricing-price {
    display: flex;
    align-items: baseline;
    gap: 0.35rem;
    margin-top: 0.75rem;
  }

  .pricing-amount {
    font-family: var(--font-display);
    font-size: 2.118rem; /* Proportion: φ² scaling for hierarchy */
    font-weight: 800;
    color: var(--fg);
    letter-spacing: -0.02em;
  }

  .pricing-unit {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg3);
  }

  .pricing-desc {
    font-size: 0.95rem;
    color: var(--fg2);
    line-height: 1.7;
    margin-top: var(--sp-xs);
  }

  .pricing-timeline {
    display: flex;
    gap: var(--sp-xs);
    align-items: center;
    padding: 0.85rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: var(--sp-md);
  }

  .pricing-timeline-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--fg3);
    text-transform: uppercase;
  }

  .pricing-timeline-value {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 600;
  }

  .pricing-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
    flex-grow: 1;
    margin-bottom: var(--sp-lg);
  }

  .pricing-feature {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-xs);
    font-size: 0.9rem;
    color: var(--fg2);
    line-height: 1.5;
  }

  .pricing-feature-arrow {
    color: var(--accent);
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 1rem;
    line-height: 1.2;
  }

  .pricing-cta {
    width: 100%;
    justify-content: center;
    text-align: center;
  }

  @media (max-width: 1024px) {
    .pricing-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    
    .pricing-card--featured {
      grid-column: span 2;
      transform: scale(1);
    }
  }

  @media (max-width: 640px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }

    .pricing-card--featured {
      grid-column: span 1;
    }

    .pricing-card {
      padding: var(--sp-md);
    }
  }
</style>
