---
// Services.astro — 3x2 service grid
import { Image } from 'astro:assets';
import { services } from '../data/services';

const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/services/*.{jpeg,jpg,png,gif}');
---

<section id="services" class="section">
  <div class="container">
    <span class="section-label">// 002 — Services</span>
    <h2 class="services-heading">
      Layanan<br />
      <em>Kami.</em>
    </h2>

    <div class="services-grid">
      {services.map((service) => {
        const imagePath = `/src/assets/images/services/${service.imageName}`;
        const image = images[imagePath];

        return (
          <div class="service-card">
            <div class="service-icon-wrapper">
              {image ? (
                <Image 
                  src={image()} 
                  alt={service.name} 
                  class="service-illustration"
                  width={320}
                  height={320}
                  quality="high"
                />
              ) : (
                <span class="service-emoji">{service.icon}</span>
              )}
            </div>
            <h3 class="service-name">{service.name}</h3>
            <p class="service-desc">{service.desc}</p>
            <div class="service-stack">
              {service.stack.map((tech) => (
                <span class={`service-tag ${service.accentStack ? 'service-tag--accent' : ''}`}>
                  {tech}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .services-heading {
    margin-bottom: var(--sp-lg);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .service-card {
    padding: var(--sp-lg); /* φ² */
    border: 0.5px solid var(--border);
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s var(--ease-out-expo);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-md); /* φ² */
  }

  .service-card:hover {
    background-color: var(--bg2);
    border-color: var(--border2);
  }

  .service-icon-wrapper {
    width: var(--sp-3xl); /* φ⁴ ≈ 110px */
    height: var(--sp-3xl);
    margin-bottom: var(--sp-2xs);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-illustration {
    width: 100%;
    height: auto;
    object-fit: contain;
    /* Blend mode to discard black pixels */
    mix-blend-mode: screen;
    /* Aggressive contrast to crush near-black noise, brightness to pop lines */
    filter: contrast(1.2) brightness(1.2);
    /* Radial mask to fade the edges of the image box into transparency */
    -webkit-mask-image: radial-gradient(circle, white 40%, transparent 75%);
    mask-image: radial-gradient(circle, white 40%, transparent 75%);
    transition: transform 0.5s var(--ease-out-expo);
  }

  .service-card:hover .service-illustration {
    transform: scale(1.1) rotate(-2deg);
  }

  .service-emoji {
    font-size: 1.75rem;
  }

  .service-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--fg);
  }

  .service-desc {
    font-size: 0.88rem;
    color: var(--fg2);
    line-height: 1.65;
    flex-grow: 1;
  }

  .service-stack {
    display: flex;
    gap: var(--sp-2xs);
    flex-wrap: wrap;
    justify-content: center;
    margin-top: var(--sp-xs);
  }

  .service-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 0.25rem 0.5rem;
    border: 0.5px solid var(--border2);
    color: var(--fg3);
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .service-card:hover .service-tag {
    border-color: var(--fg3);
    color: var(--fg2);
  }

  .service-tag--accent {
    border-color: var(--accent);
    color: var(--accent);
  }

  .service-card:hover .service-tag--accent {
    border-color: var(--accent);
    color: var(--accent);
  }

  @media (max-width: 960px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 540px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      padding: var(--sp-md);
    }
  }
</style>
