---
// Ticker.astro — CSS-only horizontal scrolling marquee
const items = [
  'Web App',
  'Mobile App',
  'AI Integration',
  'Landing Page',
  'Dashboard',
  'E-Commerce',
  'SaaS MVP',
  'Internal Tool',
  'API Backend',
];
---

<div class="ticker" aria-hidden="true">
  <div class="ticker-track">
    {/* Doubled for seamless loop */}
    {[...items, ...items].map((item, i) => (
      <Fragment>
        <span class="ticker-item">{item}</span>
        <span class="ticker-sep">✦</span>
      </Fragment>
    ))}
  </div>
</div>

<style>
  .ticker {
    width: 100%;
    overflow: hidden;
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    padding: var(--sp-md) 0; /* φ¹ */
    background-color: var(--bg);
  }

  .ticker-track {
    display: flex;
    align-items: center;
    gap: var(--sp-md); /* φ¹ */
    white-space: nowrap;
    animation: ticker-scroll 30s linear infinite;
    width: max-content;
  }

  .ticker-item {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    color: var(--fg3);
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .ticker-sep {
    color: var(--accent);
    font-size: 0.65rem;
    flex-shrink: 0;
    opacity: 0.7;
  }

  @media (max-width: 480px) {
    .ticker {
      padding: var(--sp-sm) 0;
    }

    .ticker-item {
      font-size: 0.65rem;
    }
  }
</style>
