---
// Footer.astro — Simple single-row footer
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <a href="/" class="footer-logo" aria-label="Kodacore Homepage">
      <span class="logo-text">Kodacore</span>
    </a>

    <span class="footer-copy">
      © {currentYear} Kodacore — Ramping, tapi serius.
    </span>

    <div class="footer-links">
      <a href="https://linkedin.com/in/kodacore" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="LinkedIn">
        LinkedIn
      </a>
      <a href="https://github.com/kodacore" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="GitHub">
        GitHub
      </a>
      <a href="https://wa.me/6281234567890" target="_blank" rel="noopener noreferrer" class="footer-link" aria-label="WhatsApp">
        WhatsApp
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--sp-2xl) 0 var(--sp-lg);
    border-top: 0.5px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  /* Pattern: KDCR Monogram Motif */
  .footer::before {
    content: "KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR KDCR";
    position: absolute;
    top: -20px;
    left: 0;
    width: 200%;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 8rem;
    color: var(--fg);
    opacity: 0.02;
    white-space: nowrap;
    pointer-events: none;
    letter-spacing: 0.2rem;
    transform: rotate(-2deg);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1180px;
    position: relative;
    z-index: 2;
  }

  .footer-logo {
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    display: flex;
    align-items: center;
  }

  .footer-logo .logo-text {
    color: var(--fg);
    transition: color 0.2s ease;
  }

  .footer-logo:hover .logo-text {
    color: var(--accent);
  }

  .footer-copy {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg3);
  }

  .footer-links {
    display: flex;
    gap: var(--sp-md);
  }

  .footer-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--fg2);
    text-decoration: none;
    transition: color 0.2s ease;
    position: relative;
    padding-bottom: 2px;
  }

  .footer-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 0.5px;
    background-color: var(--accent);
    transition: width 0.3s var(--ease-out-expo);
  }

  .footer-link:hover {
    color: var(--accent);
  }

  .footer-link:hover::after {
    width: 100%;
  }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--sp-md);
      text-align: center;
    }
  }
</style>
