---
// About.astro — The Deal section
const steps = [
  { num: '01', title: 'Discovery call', detail: 'Diskusi ide dan kelayakan teknis' },
  { num: '02', title: 'Scope & Proposal', detail: 'Dokumen lingkup kerja + harga tetap' },
  { num: '03', title: 'Build & Iterate', detail: 'Update mingguan + akses staging' },
  { num: '04', title: 'Launch & Handoff', detail: 'Deploy dan transfer kepemilikan' },
];
---

<section id="about" class="section">
  <div class="container about-grid">
    <!-- Left: Copy (φ proportion — 61.8%) -->
    <div class="about-copy">
      <span class="section-label">// 001 — The deal</span>
      <h2 class="text-balance">
        Bukan agency.<br />
        <em>Bukan freelancer.</em><br />
        Sesuatu di antaranya.
      </h2>
      <p class="about-text text-balance">
        Kodacore memadukan standar studio profesional dengan ketangkasan kolaborasi langsung. 
        Sebagai lean software partner, kami fokus pada engineering berkualitas dan transparansi total untuk memastikan visi Anda rilis menjadi produk nyata dengan standar tertinggi.
      </p>
    </div>

    <!-- Right: Process Steps (38.2%) -->
    <div class="about-steps">
      {steps.map((step) => (
        <div class="step">
          <span class="step-num">{step.num}</span>
          <div class="step-content">
            <span class="step-title">{step.title}</span>
            <span class="step-detail">{step.detail}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.618fr 1fr; /* golden ratio */
    gap: var(--sp-xl); /* φ³ */
    align-items: start;
  }

  .about-text {
    font-size: 1.125rem; /* Proportion: φ⁻¹ sync with Hero */
    color: var(--fg2);
    line-height: 1.7;
    margin-top: var(--sp-md);
    font-weight: 400;
  }

  .about-steps {
    display: flex;
    flex-direction: column;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-md);
    padding: var(--sp-md) 0; /* φ¹ */
    border-bottom: 0.5px solid var(--border);
    transition: background-color 0.25s ease;
  }

  .step:first-child {
    border-top: 0.5px solid var(--border);
  }

  .step:hover {
    background-color: rgba(240, 238, 230, 0.02);
  }

  .step-num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    flex-shrink: 0;
    padding-top: 0.15rem;
  }

  .step-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .step-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.125rem; /* Hierarchy: Primary step info */
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .step-detail {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg3);
  }

  @media (max-width: 960px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--sp-lg);
    }
  }
</style>
