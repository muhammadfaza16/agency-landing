---
// CTA.astro — Call to action with email form
---

<section id="cta" class="cta-section glow-hover">
  <div class="container">
    <div class="cta-inner glass-card shadow-deep">
      <span class="section-label">// 007 — Let's talk</span>
      <h2 class="cta-heading text-balance">
        Punya ide?<br />
        <em>Mari bangun bersama.</em>
      </h2>
      <p class="cta-sub text-balance">
        Tulis email Anda di bawah. Kami siap mulai dengan diskusi singkat minggu ini.
      </p>

      <form class="cta-form" id="cta-form">
        <input
          type="email"
          name="email"
          id="cta-email"
          class="cta-input"
          placeholder="email@anda.com"
          required
          autocomplete="email"
        />
        <button type="submit" class="btn-primary cta-submit">
          Kirim brief
        </button>
      </form>

      <div class="cta-success" id="cta-success">
        <span class="cta-success-icon">✓</span>
        <span class="cta-success-text">Terkirim. Kami akan menghubungi Anda dalam 24 jam.</span>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: var(--sp-3xl) 0;
    position: relative;
    overflow: hidden;
  }

  .cta-inner {
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
    padding: var(--sp-2xl) var(--sp-xl);
    border-radius: var(--sp-md);
  }

  .cta-inner .section-label {
    display: block;
    margin-bottom: var(--sp-sm);
  }

  .cta-heading {
    margin-bottom: var(--sp-sm);
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .cta-sub {
    font-size: 1.1rem;
    color: var(--fg2);
    margin-bottom: var(--sp-xl);
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-form {
    display: flex;
    gap: 0;
    max-width: 500px;
    margin: 0 auto;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.2);
  }

  .cta-input {
    flex: 1;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    padding: 1rem 1.5rem;
    min-height: 56px;
    background-color: var(--bg);
    color: var(--fg);
    border: 1px solid var(--border2);
    border-radius: 0;
    outline: none;
    transition: border-color 0.3s var(--ease-out-expo), box-shadow 0.3s ease;
  }

  .cta-input::placeholder {
    color: var(--fg3);
  }

  .cta-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(200, 255, 0, 0.05);
  }

  .cta-submit {
    flex-shrink: 0;
    height: 56px;
    padding: 0 2rem;
  }

  .cta-success {
    display: none;
    align-items: center;
    justify-content: center;
    gap: var(--sp-xs);
    margin-top: var(--sp-md);
    padding: var(--sp-sm);
    border: 1px solid var(--accent);
    background: rgba(200, 255, 0, 0.05);
    animation: fadeInUp 0.5s var(--ease-out-expo) forwards;
  }

  .cta-success.is-visible {
    display: flex;
  }

  .cta-success-icon {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 700;
  }

  .cta-success-text {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .cta-section {
      padding: var(--sp-xl) 0;
    }

    .cta-inner {
      padding: var(--sp-xl) var(--sp-md);
    }

    .cta-form {
      flex-direction: column;
      gap: var(--sp-xs);
    }

    .cta-input {
      width: 100%;
    }

    .cta-submit {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const form = document.getElementById('cta-form') as HTMLFormElement | null;
  const success = document.getElementById('cta-success');

  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.style.display = 'none';
      success.classList.add('is-visible');
    });
  }
</script>
